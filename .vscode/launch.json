{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File (venv)",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src:${workspaceFolder}"
            },
            "justMyCode": false,
            "skipFiles": [
                "${workspaceFolder}/bazel-*/**",
                "**/bazel-out/**"
            ]
        }
    ]
}