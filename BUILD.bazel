load("@aspect_rules_py//py:defs.bzl", "py_binary", "py_pex_binary")
load("//tools/build:build_defs.bzl", "py_library", "py_test")

# project setup
exports_files([
    "pyproject.toml",
    "src/__init__.py",
    "tests/__init__.py",
])

# --- Bandit ---
alias(
    name = "bandit",
    actual = "//tools/lint:bandit",
)

