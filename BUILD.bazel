load("@rules_python//python:defs.bzl", "py_binary", "py_library")
load("@pip//:requirements.bzl", "requirement")
load("@rules_python//python:pip.bzl", "compile_pip_requirements")
load("@rules_uv//uv:venv.bzl", "create_venv")
load("//tools:pylint.bzl", "py_lint_test")
load("//tools:pytest_test.bzl", "pytest_test")

# let bazel manage the requirements_lock.txt
compile_pip_requirements(
    name = "requirements",
    requirements_in = "requirements.txt",
    requirements_txt = "requirements_lock.txt",
)

# Create venv for IDE support from requirements_lock.txt
create_venv(
    name = "create_venv",
    requirements_txt = "//:requirements_lock.txt",
)

py_lint_test(
    name = "private_query_lint",
    srcs = glob(["src/**/*.py"]),
)

exports_files([".pylintrc", "requirements_lock.txt"])

py_binary(
    name = "private_query_cli",
    srcs = ["src/main_cli.py"],
    main = "src/main_cli.py",
    deps = [
        "private_query",
    ],
)

py_library(
    name = "private_query",
    srcs = ["src/private_query.py"],
    deps = [
        requirement("chromadb"),
    ],
)

pytest_test(
    name = "private_query_test",
    srcs = ["src/private_query_test.py"],
    deps = [
        requirement("pytest"),
    ],
)



