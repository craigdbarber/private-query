load("@aspect_rules_py//py:defs.bzl", "py_binary", "py_library", "py_test")

# project setup
exports_files([
    "ruff.toml",
    "pyproject.toml",
    ".pylintrc",
    "src/__init__.py",
    "tests/__init__.py",
    ".flake8",
])

# --- Bandit ---
alias(
    name = "bandit",
    actual = "//tools/lint:bandit",
)

# project targets

py_library(
    name = "config_util",
    srcs = ["src/config_util.py"],
    deps = ["@pypi//pyyaml"],
)

py_library(
    name = "device_util",
    srcs = ["src/device_util.py"],
    deps = ["@pypi//torch"],
)

py_library(
    name = "ollama_util",
    srcs = ["src/ollama_util.py"],
    deps = ["@pypi//ollama"],
)

py_binary(
    name = "private_query_cli",
    srcs = ["src/main_cli.py"],
    main = "src/main_cli.py",
    deps = [
        ":private_query_lib",
    ],
)

py_library(
    name = "private_query_lib",
    srcs = ["src/private_query.py"],
    deps = [
        ":chroma_util",
        ":config_util",
        ":ollama_util",
        "@pypi//chromadb",
    ],
)

py_test(
    name = "test_private_query",
    srcs = ["tests/test_private_query.py"],
    imports = ["."],
    pytest_main = True,
    deps = [
        ":private_query_lib",
        "@pypi//pytest",
    ],
)

py_library(
    name = "chroma_util",
    srcs = ["src/chroma_util.py"],
    deps = [
        ":config_util",
        ":device_util",
        "@pypi//chromadb",
        "@pypi//more_itertools",
    ],
)

# A library-only version of the above to enable linting without incompatible deps
py_library(
    name = "chroma_util_lib",
    srcs = ["src/chroma_util.py"],
    deps = [":config_util"],
)

py_test(
    name = "chroma_util_test",
    srcs = ["src/chroma_util_test.py"],
    imports = ["."],
    pytest_main = True,
    deps = [
        ":chroma_util",
        "@pypi//pytest",
    ],
)
